{
  "name": "pixel-agents",
  "displayName": "Pixel Agents",
  "description": "Pixel art office where your Claude Code agents come to life as animated characters",
  "version": "1.0.2",
  "publisher": "pablodelucca",
  "repository": {
    "type": "git",
    "url": "https://github.com/J0YY/pixel-agents-menubar"
  },
  "icon": "icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.107.0"
  },
  "build": {
    "appId": "com.pixelagents.menubar",
    "asar": true,
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist/**/*",
      "build/icon.png",
      "icon.png",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/desktop/main.js"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.png",
      "target": [
        "dir"
      ]
    }
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pixel-agents.showPanel",
        "title": "Pixel Agents: Show Panel"
      },
      {
        "command": "pixel-agents.exportDefaultLayout",
        "title": "Pixel Agents: Export Layout as Default"
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "pixel-agents-panel",
          "title": "Pixel Agents",
          "icon": "$(window)"
        }
      ]
    },
    "views": {
      "pixel-agents-panel": [
        {
          "type": "webview",
          "id": "pixel-agents.panelView",
          "name": "Pixel Agents"
        }
      ]
    },
    "configuration": {
      "title": "Pixel Agents",
      "properties": {
        "pixelAgents.externalTracking.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable detection of Claude Code and Codex sessions running in external macOS terminal windows."
        },
        "pixelAgents.externalTracking.scanIntervalMs": {
          "type": "number",
          "default": 3000,
          "minimum": 1000,
          "description": "Polling interval in milliseconds for scanning external macOS terminal agent processes."
        },
        "pixelAgents.externalTracking.enableClaude": {
          "type": "boolean",
          "default": true,
          "description": "Enable detection of external Claude Code sessions."
        },
        "pixelAgents.externalTracking.enableCodex": {
          "type": "boolean",
          "default": true,
          "description": "Enable detection of external Codex sessions."
        },
        "pixelAgents.externalTracking.enableTranscriptCorrelation": {
          "type": "boolean",
          "default": true,
          "description": "When possible, correlate external Claude processes with transcript files to improve activity detection."
        },
        "pixelAgents.logging.debug": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose Pixel Agents debug logging in the extension host."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "build:webview": "cd webview-ui && npm run build",
    "compile": "npm run check-types && npm run lint && node esbuild.js && npm run build:webview",
    "build": "npm run compile",
    "menubar": "npm run compile && electron dist/desktop/main.js",
    "menubar:pack": "npm run compile && electron-builder --mac dir",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production && npm run build:webview",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "import-tileset": "tsx scripts/import-tileset-cli.ts"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@types/node": "22.x",
    "@types/pngjs": "^6.0.5",
    "@types/vscode": "^1.107.0",
    "electron": "^35.1.4",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "npm-run-all": "^4.1.5",
    "pngjs": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
